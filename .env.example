# ============================================
# Environment Variables
# Copy this file to .env and fill in real values
# cp .env.example .env
# ============================================

# --- Database ---
# DATABASE_URL=

# --- Authentication ---
# AUTH_SECRET=               # Min 32 chars, high entropy

# --- AI / LLM ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- External Services ---
# RESEND_API_KEY=

# --- App ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
